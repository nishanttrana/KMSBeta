# Default local compose settings.
# This profile list is derived from infra/deployment/deployment.yaml.
COMPOSE_PROJECT_NAME=vecta-kms
COMPOSE_PROFILES=secrets,certs,governance,kmip_server,ekm_database,payment_crypto,compliance_dashboard,sbom_cbom,reporting_alerting,pqc_migration,data_protection,hsm_software,cloud_byok
CBOM_SCHEDULE_TENANTS=bank-alpha
# Certificate private-key protection (CRWK sealed outside DB)
# CERTS_STORAGE_MODE=db_encrypted
# CERTS_ROOT_KEY_MODE=software
# CERTS_CRWK_SEALED_PATH=/var/lib/vecta/certs/crwk.sealed
# CERTS_CRWK_PASSPHRASE_FILE=/var/lib/vecta/certs/bootstrap.passphrase
# Runtime cert materializer (writes only to in-memory runtime-certs tmpfs volume)
# CERTS_RUNTIME_MATERIALIZER_ENABLED=true
# CERTS_RUNTIME_MATERIALIZER_INTERVAL=5m
# CERTS_RUNTIME_MATERIALIZER_RENEW_BEFORE=24h
