[Unit]
Description=Vecta KMS Container (ai)
After=docker.service network-online.target
Wants=network-online.target
PartOf=vecta-containers.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/vecta
EnvironmentFile=-/etc/vecta/vecta.env
ExecStart=/bin/bash /opt/vecta/infra/scripts/compose-kms.sh up -d ai
ExecStop=/bin/bash /opt/vecta/infra/scripts/compose-kms.sh stop ai
ExecReload=/bin/bash /opt/vecta/infra/scripts/compose-kms.sh up -d ai
TimeoutStartSec=300
TimeoutStopSec=120

[Install]
WantedBy=vecta-containers.target
