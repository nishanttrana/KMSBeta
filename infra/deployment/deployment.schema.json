{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kms.vecta.io/schemas/deployment.schema.json",
  "title": "Vecta KMS DeploymentConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "kms.vecta.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "DeploymentConfig"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appliance_id",
        "created_at"
      ],
      "properties": {
        "appliance_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hsm_mode",
        "core",
        "features",
        "license"
      ],
      "properties": {
        "hsm_mode": {
          "type": "string",
          "enum": [
            "hardware",
            "software",
            "auto"
          ]
        },
        "cert_security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cert_storage_mode",
            "root_key_mode"
          ],
          "properties": {
            "cert_storage_mode": {
              "type": "string",
              "enum": [
                "db_encrypted"
              ]
            },
            "root_key_mode": {
              "type": "string",
              "enum": [
                "software",
                "hsm"
              ]
            },
            "sealed_key_path": {
              "type": "string",
              "minLength": 1
            },
            "passphrase_file_path": {
              "type": "string",
              "minLength": 1
            },
            "use_tpm_seal": {
              "type": "boolean"
            }
          }
        },
        "core": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "auth",
            "keycore",
            "audit",
            "policy"
          ],
          "properties": {
            "auth": {
              "type": "boolean",
              "const": true
            },
            "keycore": {
              "type": "boolean",
              "const": true
            },
            "audit": {
              "type": "boolean",
              "const": true
            },
            "policy": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "secrets",
            "certs",
            "governance",
            "cloud_byok",
            "hyok_proxy",
            "kmip_server",
            "qkd_interface",
            "qrng_generator",
            "ekm_database",
            "payment_crypto",
            "compliance_dashboard",
            "sbom_cbom",
            "reporting_alerting",
            "posture_management",
            "ai_llm",
            "pqc_migration",
            "crypto_discovery",
            "mpc_engine",
            "data_protection",
            "clustering"
          ],
          "properties": {
            "secrets": { "type": "boolean" },
            "certs": { "type": "boolean" },
            "governance": { "type": "boolean" },
            "cloud_byok": { "type": "boolean" },
            "hyok_proxy": { "type": "boolean" },
            "kmip_server": { "type": "boolean" },
            "qkd_interface": { "type": "boolean" },
            "qrng_generator": { "type": "boolean" },
            "ekm_database": { "type": "boolean" },
            "payment_crypto": { "type": "boolean" },
            "compliance_dashboard": { "type": "boolean" },
            "sbom_cbom": { "type": "boolean" },
            "reporting_alerting": { "type": "boolean" },
            "posture_management": { "type": "boolean" },
            "ai_llm": { "type": "boolean" },
            "pqc_migration": { "type": "boolean" },
            "crypto_discovery": { "type": "boolean" },
            "mpc_engine": { "type": "boolean" },
            "data_protection": { "type": "boolean" },
            "clustering": { "type": "boolean" }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "key",
            "max_keys",
            "max_tenants",
            "features_allowed"
          ],
          "properties": {
            "key": {
              "type": "string",
              "pattern": "^SEC-KMS-[A-Z]+-[0-9]{4}-[A-Z0-9-]+$"
            },
            "max_keys": {
              "type": "integer",
              "minimum": 1
            },
            "max_tenants": {
              "type": "integer",
              "minimum": 1
            },
            "features_allowed": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "activated_at": {
              "type": "string",
              "format": "date-time"
            },
            "status": {
              "type": "string",
              "enum": [
                "active",
                "inactive",
                "revoked",
                "expired"
              ]
            }
          }
        }
      }
    }
  }
}
