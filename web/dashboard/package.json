{
  "name": "vecta-kms-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "check:component-size": "node scripts/check-component-size.mjs",
    "build": "npm run generate:rest-catalog && npm run generate:openapi && npm run typecheck && vite build",
    "build:docker": "npm run generate:rest-catalog && npm run generate:openapi && npm run typecheck && vite build",
    "preview": "vite preview",
    "generate:rest-catalog": "node scripts/generate-rest-catalog.mjs",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "validate:openapi": "node scripts/validate-openapi.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:debug": "playwright test --debug"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.66.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "yaml": "^2.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.54.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "swagger-ui-dist": "^5.32.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  }
}
