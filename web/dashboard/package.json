{
  "name": "vecta-kms-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "check:component-size": "node scripts/check-component-size.mjs",
    "build": "npm run generate:rest-catalog && npm run typecheck && vite build",
    "build:docker": "npm run generate:rest-catalog && npm run typecheck && vite build",
    "preview": "vite preview",
    "generate:rest-catalog": "node scripts/generate-rest-catalog.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:debug": "playwright test --debug"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1",
    "yaml": "^2.7.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "@playwright/test": "^1.54.2",
    "vitest": "^2.1.8",
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.41.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
