# Security & reproducibility settings for Vecta KMS dashboard

# Enforce exact lockfile installs — fail if package-lock.json is out of sync.
# Equivalent to --ci but applies to all npm install invocations.
prefer-dedupe=true

# Block post-install lifecycle scripts from running untrusted code.
# Production builds use --ignore-scripts; dev installs use this as a safety net.
ignore-scripts=false

# Always run audit on install and fail on high+ severity.
audit=true
audit-level=high

# Suppress funding messages (noise in CI).
fund=false

# Require engines field to match the runtime — prevents running on wrong Node.
engine-strict=true

# Save exact versions (no ^ or ~) for new installs so future adds are pinned.
save-exact=true
