    {id:"key-001",name:"prod-db-master",algo:"AES-256-GCM",state:"Active",ver:"v3",kcv:"A1B2C3",ops:"847K",created:"2025-08-14",rotated:"2026-01-12",expires:"2026-04-12",tenant:"bank-alpha",purpose:"encrypt-decrypt",ivMode:"internal",opsLimit:"1M",approvalReq:false},
    {id:"key-002",name:"tls-frontend",algo:"ECDSA-P384",state:"Active",ver:"v4",kcv:"D4E5F6",ops:"234K",created:"2025-06-01",rotated:"2026-02-01",expires:"2026-05-01",tenant:"bank-alpha",purpose:"sign-verify",ivMode:"-",opsLimit:"∞",approvalReq:false},
    {id:"key-003",name:"pqc-signing",algo:"ML-DSA-65",state:"Active",ver:"v1",kcv:"G7H8I9",ops:"31K",created:"2026-01-15",rotated:"-",expires:"-",tenant:"bank-alpha",purpose:"sign-verify",ivMode:"-",opsLimit:"500K",approvalReq:true},
    {id:"key-004",name:"token-vault-kek",algo:"AES-256-GCM",state:"Active",ver:"v2",kcv:"J0K1L2",ops:"1.2M",created:"2025-03-01",rotated:"2025-12-01",expires:"2026-03-01",tenant:"fincorp",purpose:"wrap-unwrap",ivMode:"internal",opsLimit:"5M",approvalReq:false},
    {id:"key-005",name:"legacy-rsa",algo:"RSA-2048",state:"Deactivated",ver:"v1",kcv:"M3N4O5",ops:"89K",created:"2024-01-01",rotated:"-",expires:"2025-06-01",tenant:"bank-alpha",purpose:"encrypt-decrypt",ivMode:"-",opsLimit:"100K",approvalReq:false},
