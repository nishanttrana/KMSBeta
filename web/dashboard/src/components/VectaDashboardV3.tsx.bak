            <optgroup label="EdDSA"><option>Ed25519</option><option>Ed448</option></optgroup>
            <optgroup label="ECDH"><option>X25519</option><option>X448</option><option>ECDH-P256</option><option>ECDH-P384</option></optgroup>
            <optgroup label="Brainpool"><option>Brainpool-P256r1</option><option>Brainpool-P384r1</option></optgroup>
            <optgroup label="DSA (legacy)"><option>DSA-3072</option></optgroup>
          </Sel>:algoType==="pqc"?
          <Sel><optgroup label="ML-KEM (FIPS 203 — Key Encapsulation)"><option>ML-KEM-512</option><option>ML-KEM-768</option><option>ML-KEM-1024</option></optgroup>
            <optgroup label="ML-DSA (FIPS 204 — Signatures)"><option>ML-DSA-44</option><option>ML-DSA-65</option><option>ML-DSA-87</option></optgroup>
            <optgroup label="SLH-DSA (FIPS 205 — Stateless Hash Signatures)"><option>SLH-DSA-128s</option><option>SLH-DSA-128f</option><option>SLH-DSA-192s</option><option>SLH-DSA-192f</option><option>SLH-DSA-256s</option><option>SLH-DSA-256f</option></optgroup>
            <optgroup label="HSS/LMS (SP 800-208 — Stateful)"><option>HSS-LMS-SHA256-H10</option><option>HSS-LMS-SHA256-H15</option><option>HSS-LMS-SHA256-H20</option></optgroup>
            <optgroup label="XMSS (RFC 8391 — Stateful)"><option>XMSS-SHA256-H10</option><option>XMSS-SHA256-H16</option><option>XMSS-SHA256-H20</option></optgroup>
            <optgroup label="Hybrid (Classical + PQC)"><option>ECDSA-P384 + ML-DSA-65</option><option>RSA-3072 + ML-DSA-65</option><option>Ed25519 + ML-DSA-44</option><option>X25519 + ML-KEM-768</option></optgroup>
          </Sel>:
          <Sel><option>HMAC-SHA256</option><option>HMAC-SHA384</option><option>HMAC-SHA512</option><option>HMAC-SHA3-256</option><option>CMAC-AES-256</option></Sel>
        }</FG>
        <FG label="Purpose" required>
          <Sel value={purpose} onChange={e=>setPurpose(e.target.value)}>
            <option value="encrypt-decrypt">Encrypt / Decrypt</option>
            <option value="sign-verify">Sign / Verify</option>
            <option value="wrap-unwrap">Wrap / Unwrap (KEK)</option>
            <option value="mac">MAC Generate / Verify</option>
            <option value="key-agreement">Key Agreement (DH/ECDH/KEM)</option>
            <option value="derive">Key Derivation (HKDF)</option>
            <option value="all">All Operations</option>
          </Sel>
        </FG>
      </Row2>
      {algoType==="symmetric"&&<Row2>
        <FG label="IV Mode" hint="How initialization vectors are managed for this key">
          <Sel value={ivMode} onChange={e=>setIvMode(e.target.value)}>
            <option value="internal">Internal — KMS generates IV (CSPRNG, 12 bytes for GCM)</option>
            <option value="external">External — Caller provides IV (KMS validates length)</option>
            <option value="deterministic">Deterministic — HMAC-SHA256(key, plaintext)[:12] (⚠ leaks equality)</option>
          </Sel>
        </FG>
        <FG label="Key Derivation" hint="Optional: derive sub-keys from this master key">
          <Sel><option value="none">None</option><option value="hkdf-sha256">HKDF-SHA256</option><option value="hkdf-sha384">HKDF-SHA384</option><option value="kdf-counter">NIST SP 800-108 Counter Mode</option></Sel>
        </FG>
      </Row2>}
      <Row2>
        <FG label="Auto-Rotation">
          <Chk label="Enable automatic rotation" checked={rotationEnabled} onChange={()=>setRotationEnabled(!rotationEnabled)}/>
          {rotationEnabled&&<Sel><option>Every 90 days</option><option>Every 30 days</option><option>Every 180 days</option><option>Every 365 days</option><option>Custom...</option></Sel>}
        </FG>
        <FG label="Operation Limits" hint="0 = unlimited">
          <Row2><Inp placeholder="Max ops total (e.g., 1000000)"/><Sel w="100%"><option>Per lifetime</option><option>Per day</option><option>Per month</option></Sel></Row2>
        </FG>
      </Row2>
      <Row2>
        <FG label="Security Options">
          <Chk label="Require governance approval for all operations" checked={approvalReq} onChange={()=>setApprovalReq(!approvalReq)}/>
          <Chk label="Allow key export (wrapped)" checked={exportable} onChange={()=>setExportable(!exportable)}/>
          <Chk label="HSM-backed (store in Primus HSM)" checked={false}/>
          <Chk label="FIPS-only algorithms enforced" checked={true}/>
        </FG>
        <FG label="Activation">
          <Sel><option>Activate immediately</option><option>Pre-active (activate later)</option><option>Activate on specific date...</option></Sel>
        </FG>
      </Row2>
      <FG label="Labels / Tags" hint="Key-value pairs for search and policy matching">
        <Row3><Inp placeholder="environment=production"/><Inp placeholder="team=platform"/><Inp placeholder="compliance=pci-dss"/></Row3>
      </FG>
      <FG label="Description"><Txt placeholder="Optional description for this key..." rows={2}/></FG>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:8,paddingTop:12,borderTop:`1px solid ${C.border}`}}>
        <Btn onClick={()=>setModal(null)}>Cancel</Btn>
        <Btn primary>Create Key</Btn>
      </div>
    </Modal>

    {/* ── IMPORT KEY MODAL ── */}
    <Modal open={modal==="import"} onClose={()=>setModal(null)} title="Import Key Material" wide>
      <FG label="Import Method" required>
        <div style={{display:"flex",gap:8}}>
          {["Raw Key Material (Base64)","PKCS#8 / PEM","JWK (JSON Web Key)","TR-31 Key Block","PKCS#12 (.p12)","HSM Backup Blob"].map(m=>
            <Radio key={m} label={m} selected={false}/>)}
        </div>
      </FG>
      <Row2>
        <FG label="Key Name" required><Inp placeholder="imported-key-name"/></FG>
        <FG label="Tenant" required><Sel><option>bank-alpha</option><option>fincorp</option></Sel></FG>
      </Row2>
      <FG label="Key Material" required hint="Key material is envelope-encrypted immediately upon import. Plaintext never touches disk.">
        <Txt placeholder="Paste base64-encoded key material, PEM block, or JWK JSON..." rows={5}/>
      </FG>
      <Row2>
        <FG label="Algorithm" required hint="Must match the imported key material">
          <Sel><option>Auto-detect from format</option><option>AES-256</option><option>RSA-2048</option><option>RSA-4096</option><option>ECDSA-P384</option><option>ML-DSA-65</option></Sel>
        </FG>
        <FG label="Wrapping Key (if wrapped)" hint="Select the KEK that wraps this imported key">
          <Sel><option>Not wrapped (raw import)</option><option>token-vault-kek (AES-256)</option><option>import-kek-001 (RSA-4096 OAEP)</option><option>ml-kem-import (ML-KEM-768)</option></Sel>
        </FG>
      </Row2>
      <Row2>
        <FG label="Purpose"><Sel><option>encrypt-decrypt</option><option>sign-verify</option><option>wrap-unwrap</option><option>mac</option></Sel></FG>
        <FG label="Origin"><Sel><option>External — customer imported</option><option>Cloud provider (BYOK re-import)</option><option>HSM backup restore</option><option>TR-31 key block</option></Sel></FG>
      </Row2>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:8,paddingTop:12,borderTop:`1px solid ${C.border}`}}>
        <Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Import Key</Btn>
      </div>
    </Modal>

    {/* ── KEY DETAIL MODAL ── */}
    <Modal open={modal==="detail"&&selectedKey} onClose={()=>setModal(null)} title={`Key: ${selectedKey?.name||""}`} wide>
      {selectedKey&&<><Row3>
        <FG label="Key ID"><div style={{fontFamily:"monospace",fontSize:11,color:C.accent}}>{selectedKey.id}</div></FG>
        <FG label="Algorithm"><div style={{fontSize:11,color:C.text}}>{selectedKey.algo}</div></FG>
        <FG label="KCV"><div style={{fontFamily:"monospace",fontSize:11,color:C.green}}>{selectedKey.kcv}</div></FG>
      </Row3>
      <Row3>
        <FG label="State"><B c={selectedKey.state==="Active"?"green":"amber"}>{selectedKey.state}</B></FG>
        <FG label="Version"><div style={{fontSize:11,color:C.text}}>{selectedKey.ver}</div></FG>
        <FG label="Tenant"><div style={{fontSize:11,color:C.text}}>{selectedKey.tenant}</div></FG>
      </Row3>
      <Row3>
        <FG label="Purpose"><B c="blue">{selectedKey.purpose}</B></FG>
        <FG label="IV Mode"><div style={{fontSize:11,color:C.text}}>{selectedKey.ivMode}</div></FG>
        <FG label="Ops Limit"><div style={{fontSize:11,color:C.text}}>{selectedKey.opsLimit}</div></FG>
      </Row3>
      <Row3>
        <FG label="Created"><div style={{fontSize:11,color:C.dim}}>{selectedKey.created}</div></FG>
        <FG label="Last Rotated"><div style={{fontSize:11,color:C.dim}}>{selectedKey.rotated}</div></FG>
        <FG label="Expires"><div style={{fontSize:11,color:selectedKey.expires==="-"?C.dim:C.amber}}>{selectedKey.expires}</div></FG>
      </Row3>
      <FG label="Total Operations"><div style={{fontSize:18,fontWeight:700,color:C.accent}}>{selectedKey.ops}</div></FG>
      <FG label="Key Versions">
        <div style={{background:C.surface,borderRadius:7,padding:10,border:`1px solid ${C.border}`}}>
          {["v3 — Active (current) — KCV: A1B2C3 — Created: 2026-01-12","v2 — Deactivated — KCV: X7Y8Z9 — Created: 2025-10-01","v1 — Destroyed — KCV: P4Q5R6 — Created: 2025-08-14"].map(v=>
            <div key={v} style={{fontSize:10,color:C.dim,padding:"4px 0",borderBottom:`1px solid ${C.border}`,fontFamily:"monospace"}}>{v}</div>)}
        </div>
      </FG>
      <div style={{display:"flex",gap:6,marginTop:12}}>
        <Btn primary onClick={()=>setModal("rotate")}>↻ Rotate</Btn>
        <Btn onClick={()=>setModal("export")}>↗ Export (Wrapped)</Btn>
        <Btn onClick={()=>setModal(null)}>Deactivate</Btn>
        <Btn danger onClick={()=>setModal("destroy")}>✕ Destroy</Btn>
      </div></>}
    </Modal>

    {/* ── ROTATE KEY MODAL ── */}
    <Modal open={modal==="rotate"} onClose={()=>setModal(null)} title={`Rotate Key: ${selectedKey?.name||""}`}>
      <FG label="Rotation Type">
        <Radio label="Standard Rotation — Generate new version, deactivate old" selected={true}/>
        <Radio label="Re-key — Generate new key material, same ID (for compromised keys)" selected={false}/>
        <Radio label="PQC Migration — Rotate to post-quantum algorithm" selected={false}/>
      </FG>
      <FG label="New Algorithm" hint="Usually same as current. Change for PQC migration.">
        <Sel><option>{selectedKey?.algo} (same)</option><option>ML-DSA-65 (PQC migration)</option><option>ECDSA-P384 + ML-DSA-65 (hybrid)</option></Sel>
      </FG>
      <FG label="Old Version Action">
        <Sel><option>Deactivate old version (recommended)</option><option>Keep old version active (dual-active period)</option><option>Destroy old version immediately</option></Sel>
      </FG>
      <Chk label="Notify BYOK cloud connectors to sync new version" checked={true}/>
      <Chk label="Notify HYOK endpoints of rotation" checked={false}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Rotate Key</Btn></div>
    </Modal>

    {/* ── EXPORT KEY MODAL ── */}
    <Modal open={modal==="export"} onClose={()=>setModal(null)} title={`Export Key: ${selectedKey?.name||""}`}>
      <div style={{background:C.amberDim,border:`1px solid ${C.amber}`,borderRadius:8,padding:10,marginBottom:12,fontSize:10,color:C.amber}}>⚠ Key material will be exported wrapped. This is a HIGH severity audit event.</div>
      <FG label="Wrapping Key (KEK)" required hint="The exported key material will be encrypted with this KEK">
        <Sel><option>token-vault-kek (AES-256-GCM)</option><option>import-kek-001 (RSA-4096 OAEP)</option><option>ml-kem-export (ML-KEM-768)</option></Sel>
      </FG>
      <FG label="Export Format">
        <Sel><option>Raw wrapped (base64)</option><option>JWK (encrypted)</option><option>PKCS#8 (encrypted PEM)</option><option>TR-31 Key Block</option></Sel>
      </FG>
      <FG label="Justification" required><Txt placeholder="Reason for export (required for audit)..." rows={2}/></FG>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:8}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Export Key</Btn></div>
    </Modal>

    {/* ── DESTROY KEY MODAL ── */}
    <Modal open={modal==="destroy"} onClose={()=>setModal(null)} title={`⚠ Destroy Key: ${selectedKey?.name||""}`}>
      <div style={{background:C.redDim,border:`1px solid ${C.red}`,borderRadius:8,padding:12,marginBottom:12,fontSize:11,color:C.red}}>
        <strong>CRITICAL: This action is irreversible.</strong><br/>All key material will be zeroized. Data encrypted with this key will become permanently unrecoverable.
      </div>
      <FG label="Destruction Method">
        <Radio label="Soft Destroy — Zeroize material, keep metadata for audit (recommended)" selected={true}/>
        <Radio label="Hard Destroy — Remove all traces including metadata" selected={false}/>
      </FG>
      <FG label="Pre-Destroy Checks">
        <Chk label="I confirm no active workloads depend on this key" checked={false}/>
        <Chk label="I have verified backup/re-encryption is complete" checked={false}/>
        <Chk label="I understand this is irreversible" checked={false}/>
      </FG>
      <FG label="Type key name to confirm" required><Inp placeholder={selectedKey?.name}/></FG>
      <FG label="Justification" required><Txt placeholder="Reason for destruction (required for audit)..." rows={2}/></FG>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:8}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn danger>Destroy Key Permanently</Btn></div>
    </Modal>

    {/* ── GENERATE PQC KEY MODAL ── */}
    <Modal open={modal==="generate-pqc"} onClose={()=>setModal(null)} title="Generate Post-Quantum Key" wide>
      <div style={{background:C.purpleDim,border:`1px solid ${C.purple}`,borderRadius:8,padding:10,marginBottom:12,fontSize:10,color:C.purple}}>⚛ Post-Quantum Cryptography — NIST FIPS 203/204/205 approved algorithms</div>
      <Row2>
        <FG label="PQC Algorithm" required>
          <Sel><optgroup label="Key Encapsulation (FIPS 203)"><option>ML-KEM-512 (128-bit security)</option><option>ML-KEM-768 (192-bit security)</option><option>ML-KEM-1024 (256-bit security)</option></optgroup>
            <optgroup label="Digital Signatures (FIPS 204)"><option>ML-DSA-44 (128-bit security)</option><option>ML-DSA-65 (192-bit security)</option><option>ML-DSA-87 (256-bit security)</option></optgroup>
            <optgroup label="Hash-Based Signatures (FIPS 205)"><option>SLH-DSA-128s (small, slow)</option><option>SLH-DSA-128f (fast, large)</option><option>SLH-DSA-256f (256-bit, fast)</option></optgroup>
            <optgroup label="Stateful (SP 800-208)"><option>HSS/LMS (⚠ OTS index tracking required)</option><option>XMSS (⚠ OTS index tracking required)</option></optgroup></Sel>
        </FG>
        <FG label="Hybrid Mode" hint="Combine PQC with classical for backward compatibility">
          <Sel><option>Pure PQC only</option><option>Hybrid: ECDSA-P384 + ML-DSA-65</option><option>Hybrid: RSA-3072 + ML-DSA-65</option><option>Hybrid: X25519 + ML-KEM-768</option></Sel>
        </FG>
      </Row2>
      <Row2>
        <FG label="Key Name" required><Inp placeholder="pqc-signing-key-001"/></FG>
        <FG label="Purpose"><Sel><option>sign-verify</option><option>key-encapsulation</option><option>key-agreement</option></Sel></FG>
      </Row2>
      <Chk label="Store in HSM (if HSM supports PQC)" checked={false}/>
      <Chk label="Auto-generate classical fallback key (for migration period)" checked={true}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Generate PQC Key</Btn></div>
    </Modal>
  </div>;
};

// ═══════════════════════════════════
// TAB: CRYPTO CONSOLE (interactive encrypt/decrypt/sign/verify)
// ═══════════════════════════════════
const Crypto=()=>{
  const [op,setOp]=useState("Encrypt");
  const [modal,setModal]=useState(null);
  return <div>
    <Tabs tabs={["Encrypt","Decrypt","Sign","Verify","Wrap","Unwrap","MAC","Hash","KEM Encapsulate","KEM Decapsulate","Key Derive","Random"]} active={op} onChange={setOp}/>
    <Row2>
      <Card>
        <FG label="Select Key" required><Sel><option>prod-db-master (AES-256-GCM)</option><option>tls-frontend (ECDSA-P384)</option><option>pqc-signing (ML-DSA-65)</option><option>token-vault-kek (AES-256-GCM)</option></Sel></FG>
        {(op==="Encrypt"||op==="Decrypt")&&<>
          <FG label="Algorithm" hint="Auto-detected from key"><Inp value="AES-256-GCM" readOnly mono/></FG>
          <FG label="IV Mode"><Sel><option>Internal (KMS generates 12-byte IV)</option><option>External (provide your own IV)</option><option>Deterministic (HMAC-derived, ⚠ leaks equality)</option></Sel></FG>
          <FG label="AAD (Additional Authenticated Data)" hint="Optional for GCM/CCM modes"><Inp placeholder="Optional AAD (base64 or UTF-8)" mono/></FG>
        </>}
        {(op==="Sign"||op==="Verify")&&<>
          <FG label="Signature Algorithm"><Sel><option>ECDSA-SHA384 (from key)</option><option>RSA-PSS-SHA256</option><option>RSA-PKCS1-SHA256</option><option>Ed25519</option><option>ML-DSA-65 (PQC)</option></Sel></FG>
          <FG label="Signature Format"><Sel><option>Raw (DER/ASN.1)</option><option>P1363 (IEEE)</option><option>Base64</option></Sel></FG>
        </>}
        {op==="Wrap"&&<FG label="Wrapping Algorithm"><Sel><option>AES-KW (RFC 3394)</option><option>AES-KWP (RFC 5649)</option><option>RSA-OAEP-SHA256</option><option>ML-KEM-768 (PQC key encapsulation)</option></Sel></FG>}
        {op==="Hash"&&<FG label="Hash Algorithm"><Sel><option>SHA-256</option><option>SHA-384</option><option>SHA-512</option><option>SHA3-256</option><option>SHA3-384</option><option>SHA3-512</option><option>BLAKE2b-256</option></Sel></FG>}
        {op==="MAC"&&<FG label="MAC Algorithm"><Sel><option>HMAC-SHA256</option><option>HMAC-SHA384</option><option>HMAC-SHA512</option><option>CMAC-AES-256</option><option>GMAC-AES-256</option></Sel></FG>}
        {op==="Key Derive"&&<><FG label="KDF"><Sel><option>HKDF-SHA256</option><option>HKDF-SHA384</option><option>NIST SP 800-108 Counter</option><option>ECDH + HKDF</option><option>X25519 + HKDF</option></Sel></FG>
          <FG label="Derived Key Length (bits)"><Sel><option>128</option><option>192</option><option>256</option><option>384</option><option>512</option></Sel></FG>
          <FG label="Info / Context"><Inp placeholder="Application-specific context (base64)" mono/></FG>
          <FG label="Salt"><Inp placeholder="Optional salt (base64, recommended)" mono/></FG></>}
        {op==="Random"&&<><FG label="Length (bytes)"><Inp placeholder="32" type="number"/></FG>
          <FG label="Source"><Sel><option>KMS CSPRNG (crypto/rand)</option><option>HSM TRNG (hardware RNG)</option><option>QKD-seeded CSPRNG</option></Sel></FG></>}
        <FG label={op==="Verify"?"Plaintext / Message":op==="Decrypt"?"Ciphertext (Base64)":"Plaintext / Input"} required>
          <Txt placeholder={op==="Decrypt"?"Paste base64-encoded ciphertext...":"Enter plaintext or paste base64-encoded data..."} rows={4}/>
        </FG>
        {op==="Verify"&&<FG label="Signature to Verify" required><Txt placeholder="Paste base64-encoded signature..." rows={2}/></FG>}
        <FG label="Encoding"><Sel><option>Base64</option><option>UTF-8</option><option>Hex</option></Sel></FG>
        <FG label="Reference ID" hint="Your correlation ID (returned in response + audit trail)"><Inp placeholder="txn-456" mono/></FG>
        <Btn primary full>{op}</Btn>
      </Card>
      <Card>
        <FG label="Result">
          <Txt value={op==="Encrypt"?'{\n  "ciphertext": "c2FtcGxlX2VuY3J5cHRlZF9kYXRh...",\n  "iv": "dW5pcXVlX2l2X2hlcmU=",\n  "version": 3,\n  "kcv": "A1B2C3",\n  "reference_id": "txn-456"\n}':op==="Sign"?'{\n  "signature": "MEUCIQD3k8Hs...",\n  "key_version": 4,\n  "algorithm": "ECDSA-SHA384"\n}':'// Result will appear here...'} rows={12} readOnly/>
        </FG>
        <FG label="Audit Event"><div style={{fontSize:10,color:C.green,fontFamily:"monospace"}}>✅ audit.key.{op.toLowerCase()} → NATS published • Alert: LOW</div></FG>
        <FG label="Performance"><div style={{fontSize:10,color:C.dim}}>Duration: 0.8ms • FIPS: ✅ • IV Mode: internal</div></FG>
      </Card>
    </Row2>
  </div>;
};

// ═══════════════════════════════════
// TAB: SECRET VAULT (interactive)
// ═══════════════════════════════════
const Vault=()=>{
  const [modal,setModal]=useState(null);
  return <div>
    <div style={{display:"flex",gap:12,marginBottom:14}}>
      <Stat l="Secrets" v="1,284" c="accent" i="🔒"/><Stat l="Types" v="17" s="SSH, PGP, API, TLS..." c="blue" i="📋"/>
      <Stat l="Expiring (7d)" v="12" s="Action needed" c="amber" i="⏰"/><Stat l="Leases Active" v="47" c="green" i="📄"/>
    </div>
    <Section title="Secrets" actions={<><Btn small onClick={()=>setModal("create")}>+ Store Secret</Btn><Btn small onClick={()=>setModal("generate")}>🔑 Generate Key Pair</Btn></>}>
      <div style={{fontSize:10,color:C.muted}}>Secrets list with search, type filter, TTL status...</div>
    </Section>

    <Modal open={modal==="create"} onClose={()=>setModal(null)} title="Store New Secret" wide>
      <Row2>
        <FG label="Secret Name" required><Inp placeholder="prod-api-key-stripe"/></FG>
        <FG label="Secret Type" required>
          <Sel>
            <optgroup label="Credentials"><option>api_key</option><option>password</option><option>database_dsn</option><option>oauth_token</option><option>bearer_token</option></optgroup>
            <optgroup label="SSH"><option>ssh_key_ed25519</option><option>ssh_key_rsa</option><option>ssh_key_ecdsa</option></optgroup>
            <optgroup label="PGP / GPG"><option>pgp_key</option><option>gpg_key</option></optgroup>
            <optgroup label="TLS / X.509"><option>tls_cert_pem</option><option>tls_key_pem</option><option>pkcs12 (.p12)</option><option>ca_bundle</option></optgroup>
            <optgroup label="Crypto"><option>jwk (JSON Web Key)</option><option>jwks (JWK Set)</option><option>age_key</option><option>wireguard_key</option></optgroup>
            <optgroup label="Enterprise"><option>kerberos_keytab</option><option>saml_cert</option><option>license_key</option><option>env_file</option></optgroup>
            <optgroup label="Other"><option>ppk (PuTTY key)</option><option>generic_binary</option><option>generic_text</option></optgroup>
          </Sel>
        </FG>
      </Row2>
      <FG label="Secret Value" required hint="Envelope-encrypted at rest. Never stored in plaintext.">
        <Txt placeholder="Paste secret value (API key, PEM block, JSON, binary base64...)" rows={5}/>
      </FG>
      <Row2>
        <FG label="TTL (Time to Live)" hint="After expiry, GET returns 410 Gone">
          <Sel><option>No expiry</option><option>1 hour</option><option>24 hours</option><option>7 days</option><option>30 days</option><option>90 days</option><option>365 days</option><option>Custom...</option></Sel>
        </FG>
        <FG label="Delivery Format" hint="Format conversion when secret is retrieved">
          <Sel><option>As stored (raw)</option><option>PEM</option><option>OpenSSH</option><option>PPK (PuTTY)</option><option>PKCS#12</option><option>JWK</option><option>Base64</option></Sel>
        </FG>
      </Row2>
      <FG label="Labels"><Row3><Inp placeholder="environment=production"/><Inp placeholder="service=payment"/><Inp placeholder="owner=alice"/></Row3></FG>
      <Chk label="Enable auto-rotation (linked to external rotation webhook)" checked={false}/>
      <Chk label="Lease-based access (must renew TTL to maintain access)" checked={false}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Store Secret</Btn></div>
    </Modal>

    <Modal open={modal==="generate"} onClose={()=>setModal(null)} title="Generate Key Pair">
      <FG label="Key Type" required>
        <Sel><option>Ed25519 (SSH — recommended)</option><option>RSA-4096 (SSH)</option><option>ECDSA-P384 (SSH)</option><option>PGP / GPG (RSA-4096)</option><option>age (X25519)</option><option>WireGuard (Curve25519)</option></Sel>
      </FG>
      <FG label="Key Name" required><Inp placeholder="deploy-key-prod"/></FG>
      <FG label="Comment / Email" hint="For SSH: appears in public key. For PGP: user ID."><Inp placeholder="deploy@company.com"/></FG>
      <FG label="Passphrase Protection"><Sel><option>No passphrase (key encrypted by KMS envelope)</option><option>Additional passphrase (double encrypted)</option></Sel></FG>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Generate Key Pair</Btn></div>
    </Modal>
  </div>;
};

// ═══════════════════════════════════
// TAB: CERTIFICATES / PKI (interactive with PQC)
// ═══════════════════════════════════
const Certs=()=>{
  const [modal,setModal]=useState(null);
  return <div>
    <div style={{display:"flex",gap:12,marginBottom:14}}>
      <Stat l="Active Certs" v="2,847" c="green" i="📜"/><Stat l="CAs" v="4" s="1 root, 3 intermediate" c="accent" i="🏛"/>
      <Stat l="PQC Certs" v="128" s="4.5% of total" c="purple" i="⚛"/><Stat l="Expiring (30d)" v="23" c="amber" i="⏰"/>
    </div>
    <Section title="Certificate Authority" actions={<Btn small onClick={()=>setModal("create-ca")}>+ Create CA</Btn>}>
      <div style={{fontSize:10,color:C.muted,marginBottom:8}}>CA hierarchy tree...</div>
    </Section>
    <Section title="Certificates" actions={<>
      <Btn small onClick={()=>setModal("issue")}>+ Issue Certificate</Btn>
      <Btn small onClick={()=>setModal("issue-pqc")}>⚛ Issue PQC Certificate</Btn>
      <Btn small onClick={()=>setModal("upload-3p")}>↑ Upload 3rd-Party Cert</Btn>
    </>}>
      <div style={{fontSize:10,color:C.muted}}>Certificate inventory table...</div>
    </Section>

    {/* ── CREATE CA MODAL ── */}
    <Modal open={modal==="create-ca"} onClose={()=>setModal(null)} title="Create Certificate Authority" wide>
      <Row2>
        <FG label="CA Type" required>
          <Sel><option>Root CA (self-signed)</option><option>Intermediate CA (signed by parent)</option><option>Cross-Certified CA</option></Sel>
        </FG>
        <FG label="Parent CA" hint="Required for intermediate CAs">
          <Sel><option>— None (Root CA) —</option><option>Vecta Root CA (RSA-4096)</option><option>Vecta PQC Root CA (ML-DSA-87)</option></Sel>
        </FG>
      </Row2>
      <FG label="CA Signing Algorithm" required>
        <Sel>
          <optgroup label="Classical"><option>RSA-4096-SHA384</option><option>RSA-3072-SHA256</option><option>ECDSA-P384-SHA384</option><option>ECDSA-P256-SHA256</option></optgroup>
          <optgroup label="Post-Quantum (Pure PQC)"><option>ML-DSA-87 (FIPS 204 — highest security)</option><option>ML-DSA-65 (FIPS 204 — recommended)</option><option>SLH-DSA-256f (FIPS 205 — hash-based, large sigs)</option><option>SLH-DSA-128f (FIPS 205 — smaller)</option><option>HSS/LMS-SHA256 (SP 800-208 — stateful ⚠)</option><option>XMSS-SHA256 (RFC 8391 — stateful ⚠)</option></optgroup>
          <optgroup label="Hybrid (Classical + PQC)"><option>ECDSA-P384 + ML-DSA-65 (composite)</option><option>RSA-3072 + ML-DSA-65 (composite)</option><option>Ed25519 + ML-DSA-44 (composite)</option></optgroup>
        </Sel>
      </FG>
      <Row2>
        <FG label="Subject DN" required><Inp placeholder="CN=Vecta Root CA, O=Bank Corp, C=CH"/></FG>
        <FG label="Validity"><Sel><option>10 years (Root CA)</option><option>5 years (Intermediate)</option><option>3 years</option><option>1 year</option><option>Custom...</option></Sel></FG>
      </Row2>
      <FG label="Key Storage">
        <Radio label="HSM-backed (Primus HSM — FIPS 140-3 Level 3)" selected={true}/>
        <Radio label="Software vault (envelope-encrypted)" selected={false}/>
      </FG>
      <FG label="Path Length Constraint" hint="Max depth of CA chain below this CA"><Inp placeholder="1" type="number"/></FG>
      <FG label="Key Usage"><Chk label="Key Cert Sign" checked={true}/><Chk label="CRL Sign" checked={true}/><Chk label="Digital Signature" checked={false}/></FG>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Create CA</Btn></div>
    </Modal>

    {/* ── ISSUE CERTIFICATE MODAL ── */}
    <Modal open={modal==="issue"||modal==="issue-pqc"} onClose={()=>setModal(null)} title={modal==="issue-pqc"?"Issue PQC Certificate":"Issue Certificate"} wide>
      <Row2>
        <FG label="Issuing CA" required><Sel><option>Vecta Intermediate CA (ECDSA-P384)</option><option>Vecta PQC CA (ML-DSA-65)</option><option>Vecta Hybrid CA (ECDSA + ML-DSA)</option></Sel></FG>
        <FG label="Certificate Profile"><Sel>
          {modal==="issue-pqc"?<>
            <option>pqc-tls-server (ML-DSA-65 + ECDHE)</option><option>pqc-code-signing (SLH-DSA-256f)</option>
            <option>hybrid-tls (ECDSA-P384 + ML-DSA-65)</option><option>quantum-safe-smime (ML-DSA + ML-KEM)</option>
          </>:<>
            <option>TLS Server</option><option>TLS Client (mTLS)</option><option>Code Signing</option>
            <option>Email / S-MIME</option><option>Device Identity</option><option>Custom...</option>
          </>}
        </Sel></FG>
      </Row2>
      <FG label="Key Source">
        <Radio label="Server-generated key (KMS creates key pair)" selected={true}/>
        <Radio label="CSR (upload Certificate Signing Request)" selected={false}/>
      </FG>
      {modal==="issue-pqc"&&<FG label="PQC Algorithm" required>
        <Sel><option>ML-DSA-65 (recommended for TLS)</option><option>ML-DSA-87 (highest security)</option><option>SLH-DSA-128f (hash-based, no state)</option>
          <option>ECDSA-P384 + ML-DSA-65 (hybrid composite)</option></Sel>
      </FG>}
      <Row2>
        <FG label="Common Name (CN)" required><Inp placeholder="api.bank.com"/></FG>
        <FG label="Subject Alternative Names (SANs)"><Inp placeholder="api.bank.com, *.api.bank.com, 10.0.1.100" mono/></FG>
      </Row2>
      <Row2>
        <FG label="Organization"><Inp placeholder="Bank Corp"/></FG>
        <FG label="Validity"><Sel><option>365 days</option><option>90 days</option><option>30 days</option><option>730 days</option><option>Custom...</option></Sel></FG>
      </Row2>
      <FG label="Key Usage"><Chk label="Digital Signature" checked={true}/><Chk label="Key Encipherment" checked={true}/><Chk label="Key Agreement" checked={false}/></FG>
      <FG label="Extended Key Usage"><Chk label="TLS Server Auth" checked={true}/><Chk label="TLS Client Auth" checked={false}/><Chk label="Code Signing" checked={false}/><Chk label="Email Protection" checked={false}/></FG>
      <Chk label="Auto-renew via ACME (RFC 8555)" checked={false}/>
      <Chk label="Include in CRL distribution" checked={true}/>
      <Chk label="Enable OCSP stapling" checked={true}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Issue Certificate</Btn></div>
    </Modal>

    {/* ── UPLOAD 3RD-PARTY CERT MODAL ── */}
    <Modal open={modal==="upload-3p"} onClose={()=>setModal(null)} title="Upload 3rd-Party Web Certificate" wide>
      <div style={{background:C.blueDim,border:`1px solid ${C.blue}`,borderRadius:8,padding:10,marginBottom:12,fontSize:10,color:C.blue}}>
        Upload certificates issued by external CAs (DigiCert, Let's Encrypt, etc.) for the KMS web interface or other services.
      </div>
      <FG label="Certificate Purpose" required>
        <Sel><option>KMS Web Interface (HTTPS on port 443)</option><option>API Gateway (Envoy TLS termination)</option><option>KMIP Server (port 5696 TLS)</option><option>Syslog TLS (audit export)</option><option>Custom service endpoint</option></Sel>
      </FG>
      <FG label="Certificate (PEM)" required hint="Paste the certificate chain (leaf + intermediates + root)">
        <Txt placeholder="-----BEGIN CERTIFICATE-----\nMIID...paste PEM here...\n-----END CERTIFICATE-----" rows={6}/>
      </FG>
      <FG label="Private Key (PEM)" required hint="Will be envelope-encrypted and stored in Key Core">
        <Txt placeholder="-----BEGIN PRIVATE KEY-----\nMIIE...paste key here...\n-----END PRIVATE KEY-----" rows={4}/>
      </FG>
      <FG label="CA Bundle (PEM)" hint="Intermediate CA certificates (if not included above)">
        <Txt placeholder="-----BEGIN CERTIFICATE-----\n...intermediate CA...\n-----END CERTIFICATE-----" rows={3}/>
      </FG>
      <Chk label="Set as active web interface certificate (replace current)" checked={true}/>
      <Chk label="Enable OCSP stapling for this certificate" checked={true}/>
      <Chk label="Auto-renew via ACME when expiring" checked={false}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Upload & Apply Certificate</Btn></div>
    </Modal>
  </div>;
};

// ═══════════════════════════════════
// TAB: TOKENIZE / MASK (interactive)
// ═══════════════════════════════════
const Tokenize=()=>{
  const [op,setOp]=useState("Tokenize");
  const [modal,setModal]=useState(null);
  return <div>
    <Tabs tabs={["Tokenize","Detokenize","FPE Encrypt","FPE Decrypt","Mask","Redact","Field Encrypt","Envelope Encrypt"]} active={op} onChange={setOp}/>
    <Section title="" actions={<Btn small onClick={()=>setModal("vault")}>+ Create Token Vault</Btn>}>
    <Row2>
      <Card>
        {op==="Tokenize"&&<><FG label="Token Vault" required><Sel><option>credit-card-vault (format-preserving, Luhn-valid)</option><option>ssn-vault (format-preserving)</option><option>email-vault (random tokens)</option><option>iban-vault (format-preserving)</option><option>custom-vault</option></Sel></FG>
          <FG label="Tokenization Method"><Sel><option>Format Preserving (output matches input format)</option><option>Random (UUID-based token)</option><option>Deterministic (same input → same token)</option><option>Irreversible (one-way hash, no detokenize)</option></Sel></FG>
          <FG label="Input Value" required><Txt placeholder="4111-1111-1111-1111" rows={2}/></FG>
          <Chk label="Batch mode (multiple values, one per line)" checked={false}/>
          <FG label="TTL"><Sel><option>No expiry</option><option>24 hours</option><option>30 days</option><option>90 days</option></Sel></FG></>}
        {op==="Mask"&&<><FG label="Masking Pattern" required><Sel><option>Partial — show last 4 (***-**-6789)</option><option>Full mask (****************)</option><option>Hash (SHA-256 of original)</option><option>Substitute (random same-format)</option><option>Nullify (set to null)</option><option>Date shift (±random days)</option><option>Shuffle (reorder characters)</option></Sel></FG>
          <FG label="Apply To Role"><Sel><option>Analyst → partial</option><option>Admin → full access</option><option>Auditor → hash only</option><option>Developer → nullify</option></Sel></FG>
          <FG label="Input"><Txt placeholder="John Smith, SSN: 123-45-6789, DOB: 1985-03-14" rows={3}/></FG>
          <Chk label="Consistent masking (same input → same masked output)" checked={true}/></>}
        {op==="Redact"&&<><FG label="Redaction Mode"><Sel><option>Auto-detect PII (regex patterns)</option><option>Custom regex patterns</option><option>NER-based entity detection (AI)</option></Sel></FG>
          <FG label="PII Patterns to Detect"><Chk label="Email addresses" checked={true}/><Chk label="Phone numbers" checked={true}/><Chk label="SSN / National ID" checked={true}/><Chk label="Credit card numbers" checked={true}/><Chk label="IBAN" checked={true}/><Chk label="IP addresses" checked={false}/><Chk label="Custom regex..." checked={false}/></FG>
          <FG label="Input Document" required><Txt placeholder="Please contact John at john.doe@email.com or 555-123-4567..." rows={4}/></FG>
          <FG label="Redaction Action"><Sel><option>Replace with [REDACTED]</option><option>Replace with placeholder (e.g., [EMAIL], [PHONE])</option><option>Replace with *** of same length</option><option>Remove entirely</option></Sel></FG></>}
        {op==="Field Encrypt"&&<><FG label="Encryption Algorithm"><Sel><option>AES-GCM-256 (authenticated encryption)</option><option>AES-SIV (deterministic, searchable)</option><option>ChaCha20-Poly1305</option></Sel></FG>
          <FG label="KEK (Key Encryption Key)" required><Sel><option>prod-db-master (AES-256-GCM)</option><option>token-vault-kek (AES-256-GCM)</option></Sel></FG>
          <FG label="JSON Document" required><Txt placeholder='{"name": "John", "ssn": "123-45-6789", "email": "john@email.com"}' rows={4}/></FG>
          <FG label="Fields to Encrypt" hint="JSONPath expressions"><Inp placeholder="$.ssn, $.email, $.credit_card" mono/></FG>
          <Chk label="Searchable encryption (AES-SIV for equality queries)" checked={false}/></>}
        {(op==="FPE Encrypt"||op==="FPE Decrypt")&&<><FG label="FPE Algorithm"><Sel><option>FF1 (NIST SP 800-38G Rev 1)</option><option>FF3-1 (NIST SP 800-38G Rev 1, shorter inputs)</option></Sel></FG>
          <FG label="Character Set"><Sel><option>Numeric (0-9)</option><option>Alphanumeric lowercase</option><option>Alphanumeric mixed case</option><option>Custom alphabet...</option></Sel></FG>
          <FG label="Tweak" hint="FPE tweak value (context binding)"><Inp placeholder="Optional tweak (hex)" mono/></FG>
          <FG label="Input" required><Inp placeholder="4111111111111111" mono/></FG></>}
        {op==="Envelope Encrypt"&&<><FG label="KEK" required><Sel><option>prod-db-master (AES-256-GCM)</option><option>ml-kem-768-001 (PQC)</option></Sel></FG>
          <FG label="DEK Algorithm"><Sel><option>AES-256-GCM (generated per request)</option><option>ChaCha20-Poly1305</option></Sel></FG>
          <FG label="Plaintext" required><Txt placeholder="Data to encrypt..." rows={4}/></FG>
          <div style={{fontSize:10,color:C.dim,marginTop:8}}>Flow: Generate DEK → Encrypt data with DEK → Wrap DEK with KEK → Return &#123;wrapped_dek, ciphertext, iv&#125;</div></>}
        <Btn primary full style={{marginTop:10}}>{op}</Btn>
      </Card>
      <Card><FG label="Result"><Txt value="// Output will appear here..." rows={16} readOnly/></FG></Card>
    </Row2></Section>

    <Modal open={modal==="vault"} onClose={()=>setModal(null)} title="Create Token Vault" wide>
      <Row2>
        <FG label="Vault Name" required><Inp placeholder="credit-card-vault"/></FG>
        <FG label="Token Type" required><Sel><option>credit_card (PAN with Luhn validation)</option><option>ssn (US Social Security Number)</option><option>email</option><option>phone</option><option>iban</option><option>custom (provide regex)</option></Sel></FG>
      </Row2>
      <Row2>
        <FG label="Token Format"><Sel><option>Format Preserving (same length/charset as input)</option><option>Random UUID</option><option>Prefixed (tok_...)</option></Sel></FG>
        <FG label="Encryption Key" required hint="KEK used to envelope-encrypt original values"><Sel><option>token-vault-kek (AES-256-GCM)</option><option>Create new key...</option></Sel></FG>
      </Row2>
      <FG label="Custom Regex" hint="Only for 'custom' token type"><Inp placeholder="^\d{3}-\d{2}-\d{4}$" mono/></FG>
      <Chk label="Allow detokenization (reversible)" checked={true}/>
      <Chk label="Deduplication (same input always returns same token)" checked={true}/>
      <Chk label="Token expiry (auto-delete after TTL)" checked={false}/>
      <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>setModal(null)}>Cancel</Btn><Btn primary>Create Vault</Btn></div>
    </Modal>
  </div>;
};

// ═══════════════════════════════════
// TAB: PAYMENT CRYPTO (interactive)
// ═══════════════════════════════════
const Payment=()=>{
  const [op,setOp]=useState("TR-31 Create");
  return <div>
    <Tabs tabs={["TR-31 Create","TR-31 Translate","PIN Translate","PIN Verify","PVV Generate","CVV Compute","MAC Generate","ISO 20022 Sign","ISO 20022 Encrypt","LAU Generate"]} active={op} onChange={setOp}/>
    <Row2>
      <Card>
        {op==="TR-31 Create"&&<><FG label="Key to Wrap" required><Sel><option>zpk-001 (ZPK — Zone PIN Key)</option><option>bdk-001 (BDK — Base Derivation Key)</option><option>pvk-001 (PVK — PIN Verification Key)</option></Sel></FG>
          <FG label="KBPK (Key Block Protection Key)" required><Sel><option>kbpk-master (AES-256)</option><option>kbpk-partner-001 (3DES)</option></Sel></FG>
          <FG label="TR-31 Version"><Sel><option>D — AES CMAC (recommended)</option><option>B — 3DES variant</option><option>C — 3DES with key derivation</option></Sel></FG>
          <FG label="Key Usage"><Sel><option>P0 — PIN Encryption</option><option>B0 — BDK</option><option>D0 — Data Encryption (Symmetric)</option><option>M0 — ISO 9797-1 MAC (Algorithm 1)</option><option>M3 — ISO 9797-1 MAC (Algorithm 3)</option><option>K0 — Key Encryption / Wrapping</option><option>V0 — PIN Verification (PVV)</option></Sel></FG>
          <FG label="Export Mode"><Sel><option>E — Exportable per TR-31 rules</option><option>N — Not exportable</option><option>S — Sensitive (exportable under KEK)</option></Sel></FG></>}
        {op==="PIN Translate"&&<><FG label="Source PIN Block Format"><Sel><option>ISO 0 (Visa format)</option><option>ISO 1</option><option>ISO 3</option><option>ISO 4 (AES-encrypted, recommended)</option></Sel></FG>
          <FG label="Target PIN Block Format"><Sel><option>ISO 4 (AES)</option><option>ISO 0 (3DES)</option></Sel></FG>
          <FG label="Source ZPK"><Sel><option>zpk-incoming (AES-256)</option></Sel></FG>
          <FG label="Target ZPK"><Sel><option>zpk-outgoing (AES-256)</option></Sel></FG>
          <FG label="PIN Block (hex)" required><Inp placeholder="0412AC8967BFCD01" mono/></FG>
          <FG label="PAN (for format 0/4)"><Inp placeholder="4111111111111111" mono/></FG></>}
        {op==="CVV Compute"&&<><FG label="CVK (Card Verification Key)" required><Sel><option>cvk-visa-001 (3DES)</option><option>cvk-mc-001 (3DES)</option></Sel></FG>
          <FG label="PAN" required><Inp placeholder="4111111111111111" mono/></FG>
          <FG label="Expiry (YYMM)" required><Inp placeholder="2612" mono/></FG>
          <FG label="Service Code" required><Inp placeholder="101" mono/></FG>
          <FG label="CVV Type"><Sel><option>CVV1 (magnetic stripe)</option><option>CVV2 (card-not-present)</option><option>iCVV (chip)</option><option>dCVV (dynamic)</option></Sel></FG></>}
        {op==="ISO 20022 Sign"&&<><FG label="Signing Key" required><Sel><option>iso20022-sign-001 (RSA-2048-SHA256)</option><option>iso20022-sign-pqc (ML-DSA-65)</option></Sel></FG>
          <FG label="XML Document" required><Txt placeholder='<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pacs.008">...</Document>' rows={5}/></FG>
          <FG label="Signature Type"><Sel><option>XMLDSig (enveloped)</option><option>XMLDSig (detached)</option><option>LAU (Local Authentication)</option></Sel></FG>
          <FG label="Canonicalization"><Sel><option>Exclusive XML C14N</option><option>Inclusive XML C14N</option></Sel></FG></>}
        {op==="ISO 20022 Encrypt"&&<><FG label="Encryption Key" required><Sel><option>iso20022-enc-001 (AES-256-GCM)</option></Sel></FG>
          <FG label="XML Document" required><Txt placeholder="<Document>...sensitive payment fields...</Document>" rows={4}/></FG>
          <FG label="Fields to Encrypt" hint="XPath expressions for selective field encryption"><Inp placeholder="//CdtrAcct/Id/IBAN, //DbtrAcct/Id/IBAN" mono/></FG>
          <FG label="Encryption Scope"><Sel><option>Full document encryption</option><option>Selective field encryption (XPath)</option></Sel></FG></>}
        <Btn primary full style={{marginTop:10}}>Execute</Btn>
      </Card>
      <Card><FG label="Result"><Txt value="// Output will appear here..." rows={16} readOnly/></FG></Card>
    </Row2>
  </div>;
};

// ═══════════════════════════════════
// REMAINING TABS (interactive stubs with modals)
// ═══════════════════════════════════
const Home=()=>{
  const [modal,setModal]=useState(null);
  return <div>
    <div style={{display:"flex",gap:12,marginBottom:14}}>
      <Stat l="Keys" v="4,847" c="accent" i="🔑"/><Stat l="Secrets" v="1,284" c="blue" i="🔒"/><Stat l="Certs" v="2,847" c="green" i="📜"/>
      <Stat l="Ops Today" v="2.1M" c="purple" i="⚡"/><Stat l="Alerts" v="19 open" s="2 critical" c="red" i="🔔"/>
    </div>
    <Row2>
      <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>🔒 DISK ENCRYPTION</div>
        <div style={{fontSize:10,color:C.dim}}>AES-256-XTS LUKS2 • 34.2/120 GB (28.5%) • Integrity: ✅ Passed</div>
        <div style={{fontSize:10,color:C.dim}}>Recovery: 3-of-5 Shamir shares</div>
        <Btn small style={{marginTop:6}} onClick={()=>setModal("fde")}>Manage FDE</Btn>
      </Card>
      <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>🛡 FIPS MODE</div>
        <B c="green">FIPS STRICT</B>
        <div style={{fontSize:10,color:C.dim,marginTop:4}}>Go: BoringCrypto ✅ • TLS: 1.2+ FIPS • RNG: CTR_DRBG • Violations (24h): 0</div>
        <Btn small style={{marginTop:6}} onClick={()=>setModal("fips")}>Configure FIPS</Btn>
      </Card>
    </Row2>
    <Modal open={modal==="fde"} onClose={()=>setModal(null)} title="Full Disk Encryption Management">
      <FG label="Encryption"><div style={{fontSize:11,color:C.green}}>AES-256-XTS via LUKS2 — Active ✅</div></FG>
      <FG label="Actions"><Btn small>Run Integrity Check</Btn><Btn small style={{marginLeft:6}}>Rotate Volume Key</Btn><Btn small style={{marginLeft:6}}>Test Recovery Shares</Btn></FG>
      <FG label="Recovery Shares (Shamir 3-of-5)">
        <div style={{fontSize:10,color:C.dim}}>Share 1: Held by Admin A ✅ • Share 2: Held by Admin B ✅ • Share 3: Escrow ✅ • Share 4: Safe ✅ • Share 5: DR Site ✅</div>
      </FG>
    </Modal>
    <Modal open={modal==="fips"} onClose={()=>setModal(null)} title="FIPS Compliance Mode">
      <FG label="Mode"><Sel><option>Strict FIPS (non-approved algos blocked)</option><option>Standard (all algos, FIPS violations logged)</option></Sel></FG>
      <FG label="Crypto Library"><div style={{fontSize:11,color:C.green}}>Go BoringCrypto — FIPS 140-3 validated ✅</div></FG>
      <FG label="TLS"><Sel><option>TLS 1.2+ with FIPS cipher suites only</option><option>TLS 1.3 only</option></Sel></FG>
      <FG label="RNG"><Sel><option>CTR_DRBG (FIPS-approved)</option><option>HMAC_DRBG</option><option>HSM TRNG</option></Sel></FG>
      <Btn primary style={{marginTop:8}}>Apply FIPS Settings</Btn>
    </Modal>
  </div>;
};

const BYOK=()=>{const [m,sM]=useState(null);return <div>
  <Section title="Cloud Connectors" actions={<Btn small onClick={()=>sM("add")}>+ Add Cloud Connector</Btn>}>
    {[["AWS KMS","28 keys","ap-south-1, eu-west-1"],["Azure Key Vault","15 keys","westeurope, eastus"],["Google Cloud KMS","8 keys","europe-west1"],["Oracle Cloud Vault","3 keys","eu-frankfurt-1"]].map(([n,k,r])=>
      <Card key={n} style={{marginBottom:6}} onClick={()=>sM("import")}><div style={{display:"flex",justifyContent:"space-between"}}><div><div style={{fontSize:12,color:C.text,fontWeight:600}}>{n}</div><div style={{fontSize:10,color:C.dim}}>{k} • {r}</div></div><B c="green">Synced</B></div></Card>)}
  </Section>
  <Modal open={m==="add"} onClose={()=>sM(null)} title="Add Cloud Connector" wide>
    <FG label="Cloud Provider" required><Sel><option>AWS KMS</option><option>Azure Key Vault</option><option>Google Cloud KMS</option><option>Oracle Cloud Vault</option></Sel></FG>
    <FG label="Authentication"><Sel><option>IAM Role (recommended)</option><option>Access Key + Secret</option><option>Service Account JSON</option><option>Managed Identity</option></Sel></FG>
    <FG label="Region(s)"><Inp placeholder="eu-west-1, us-east-1" mono/></FG>
    <FG label="Auto-sync Interval"><Sel><option>Every 5 minutes</option><option>Every 15 minutes</option><option>Hourly</option><option>Manual only</option></Sel></FG>
    <Chk label="Auto-rotate cloud keys when Vecta key rotates" checked={true}/>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Add Connector</Btn></div>
  </Modal>
  <Modal open={m==="import"} onClose={()=>sM(null)} title="Import Key to Cloud">
    <FG label="Vecta Key to Import" required><Sel><option>prod-db-master (AES-256-GCM)</option><option>tls-frontend (ECDSA-P384)</option></Sel></FG>
    <FG label="Target Cloud"><Sel><option>AWS KMS — eu-west-1</option><option>Azure Key Vault — westeurope</option></Sel></FG>
    <FG label="Cloud Key Alias"><Inp placeholder="alias/vecta-prod-db" mono/></FG>
    <Chk label="Enable automatic sync on rotation" checked={true}/>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Import to Cloud</Btn></div>
  </Modal>
</div>;};

const HYOK=()=>{const [m,sM]=useState(null);return <div>
  <Section title="HYOK Proxy Endpoints" actions={<Btn small onClick={()=>sM("add")}>+ Configure Endpoint</Btn>}>
    {[["Microsoft DKE","M365 Double Key Encryption","RSA-2048","12,847 decrypt/day"],["Salesforce Cache-Only","Shield Platform Encryption","AES-256","3,201 wrap/day"],["Google Cloud EKM","External Key Manager","RSA-3072","847 ops/day"]].map(([n,d,a,v])=>
      <Card key={n} style={{marginBottom:6}}><div style={{display:"flex",justifyContent:"space-between"}}><div><div style={{fontSize:12,color:C.text,fontWeight:600}}>{n}</div><div style={{fontSize:10,color:C.dim}}>{d} • {a}</div></div><div style={{textAlign:"right"}}><B c="green">Active</B><div style={{fontSize:9,color:C.dim,marginTop:2}}>{v}</div></div></div></Card>)}
  </Section>
  <Modal open={m==="add"} onClose={()=>sM(null)} title="Configure HYOK Endpoint" wide>
    <FG label="Protocol" required><Sel><option>Microsoft DKE (Double Key Encryption)</option><option>Salesforce Cache-Only Key Service</option><option>Google Cloud External Key Manager</option><option>Generic HYOK (custom REST API)</option></Sel></FG>
    <FG label="Vecta Key" required><Sel><option>dke-key-001 (RSA-2048)</option><option>sf-cache-key (AES-256)</option><option>Create new key...</option></Sel></FG>
    <FG label="Endpoint URL" hint="The well-known URL the cloud service will call"><Inp placeholder="https://kms.bank.com/.well-known/dke/keys/dke-key-001" mono/></FG>
    <Chk label="Require policy check before serving HYOK request" checked={true}/>
    <Chk label="Require governance approval for configuration changes" checked={true}/>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Configure Endpoint</Btn></div>
  </Modal>
</div>;};

const EKM=()=>{const [m,sM]=useState(null);return <div>
  <Section title="TDE Agents" actions={<Btn small onClick={()=>sM("deploy")}>+ Deploy Agent</Btn>}>
    {[["MSSQL-Prod-01","10.0.5.10","SQL Server 2022","Active"],["MSSQL-Prod-02","10.0.5.11","SQL Server 2022","Active"],["MSSQL-DR-01","10.0.6.10","SQL Server 2019","Standby"]].map(([n,ip,v,s])=>
      <Card key={n} style={{marginBottom:6}} onClick={()=>sM("provision")}><div style={{display:"flex",justifyContent:"space-between"}}><div><div style={{fontSize:12,color:C.text,fontWeight:600}}>{n}</div><div style={{fontSize:10,color:C.dim,fontFamily:"monospace"}}>{ip} • {v}</div></div><B c={s==="Active"?"green":"amber"}>{s}</B></div></Card>)}
  </Section>
  <Modal open={m==="deploy"} onClose={()=>sM(null)} title="Deploy EKM Agent">
    <FG label="Database Type" required><Sel><option>Microsoft SQL Server (TDE)</option><option>Oracle Database (TDE)</option></Sel></FG>
    <FG label="Host IP" required><Inp placeholder="10.0.5.12" mono/></FG>
    <FG label="Agent Authentication"><Sel><option>mTLS client certificate</option><option>API key</option></Sel></FG>
    <FG label="TDE Key Algorithm"><Sel><option>AES-256</option><option>AES-128</option></Sel></FG>
    <FG label="Rotation Cycle"><Sel><option>90 days</option><option>180 days</option><option>365 days</option></Sel></FG>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Deploy Agent</Btn></div>
  </Modal>
  <Modal open={m==="provision"} onClose={()=>sM(null)} title="Provision TDE Key">
    <FG label="Key Name"><Inp placeholder="tde-mssql-prod-03"/></FG>
    <FG label="Algorithm"><Sel><option>AES-256</option></Sel></FG>
    <FG label="Target Agent"><Sel><option>MSSQL-Prod-01</option><option>MSSQL-Prod-02</option></Sel></FG>
    <Btn primary style={{marginTop:8}}>Provision Key</Btn>
  </Modal>
</div>;};

const HSM=()=>{const [m,sM]=useState(null);return <div>
  <Row2>
    <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>CONNECTION</div>
      {[["Mode","Hardware PKCS#11"],["Model","Primus X HSM"],["Firmware","v3.8.2"],["IP","10.0.3.50:2300"],["FIPS","Level 3"],["Partition","kms-prod"],["MEK","Loaded ✅"],["Keys","47"]].map(([k,v])=>
        <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"3px 0",fontSize:10}}><span style={{color:C.muted}}>{k}</span><span style={{color:C.text,fontFamily:"monospace"}}>{v}</span></div>)}
    </Card>
    <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>OPERATIONS (24h)</div>
      {[["Encrypt/Decrypt","847K/day"],["Sign/Verify","234K/day"],["Key Gen","12/day"],["Wrap/Unwrap","1.2K/day"],["Avg Latency","0.8ms"],["Uptime","99.999%"]].map(([k,v])=>
        <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"3px 0",fontSize:10}}><span style={{color:C.muted}}>{k}</span><span style={{color:C.accent}}>{v}</span></div>)}
    </Card>
  </Row2>
  <Section title="HSM Actions" actions={<><Btn small onClick={()=>sM("gen")}>Generate Key in HSM</Btn><Btn small onClick={()=>sM("import-hsm")}>Import to HSM</Btn><Btn small>Backup HSM State</Btn></>}><div/></Section>
  <Modal open={m==="gen"} onClose={()=>sM(null)} title="Generate Key in HSM">
    <FG label="Algorithm" required><Sel><option>AES-256</option><option>RSA-2048</option><option>RSA-4096</option><option>ECDSA-P384</option><option>Ed25519</option></Sel></FG>
    <FG label="Key Label" required><Inp placeholder="hsm-key-label" mono/></FG>
    <FG label="HSM Partition"><Sel><option>kms-prod</option><option>kms-backup</option></Sel></FG>
    <FG label="Key Attributes"><Chk label="Extractable (can be wrapped and exported)" checked={false}/><Chk label="Sensitive (never appears in plaintext)" checked={true}/><Chk label="Token object (persists on HSM)" checked={true}/></FG>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Generate in HSM</Btn></div>
  </Modal>
</div>;};

const QKD=()=>{const [m,sM]=useState(null);return <div>
  <Row2>
    <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>LINK STATUS</div>
      {[["Protocol","ETSI GS QKD 014"],["Status","Key streaming ✅"],["Source","QKD Node A (DC1)"],["Destination","QKD Node B (DC2)"],["Key Rate","1,200 keys/sec"],["QBER","2.1% (OK < 11%)"],["Distance","47 km fiber"]].map(([k,v])=>
        <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"3px 0",fontSize:10}}><span style={{color:C.muted}}>{k}</span><span style={{color:C.text,fontFamily:"monospace"}}>{v}</span></div>)}
    </Card>
    <Card><div style={{fontSize:11,color:C.muted,fontWeight:600,marginBottom:6}}>KEY POOL</div>
      <div style={{fontSize:22,fontWeight:700,color:C.accent}}>847,293</div>
      <div style={{fontSize:10,color:C.dim}}>available quantum keys (68% full)</div>
      <Bar pct={68} color={C.green}/>
      <Btn small primary style={{marginTop:8}} onClick={()=>sM("inject")}>Inject into Key Core</Btn>
    </Card>
  </Row2>
  <Modal open={m==="inject"} onClose={()=>sM(null)} title="Inject QKD Keys into Key Core">
    <FG label="Number of Keys"><Inp placeholder="100" type="number"/></FG>
    <FG label="Key Purpose"><Sel><option>AES-256-GCM encryption keys</option><option>HMAC-SHA256 authentication keys</option><option>KEK (Key Encryption Keys)</option></Sel></FG>
    <FG label="Target Tenant"><Sel><option>bank-alpha</option><option>fincorp</option><option>All tenants (pool)</option></Sel></FG>
    <FG label="Min QBER Threshold"><Inp placeholder="5" type="number" mono/><span style={{fontSize:9,color:C.muted}}>% (reject keys above this)</span></FG>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Inject Keys</Btn></div>
  </Modal>
</div>;};

const MPC=()=>{const [m,sM]=useState(null);return <div>
  <Section title="MPC Ceremonies" actions={<Btn small onClick={()=>sM("dkg")}>+ Start DKG Ceremony</Btn>}>
    <div style={{fontSize:10,color:C.dim}}>Active ceremonies and share inventory...</div>
  </Section>
  <Modal open={m==="dkg"} onClose={()=>sM(null)} title="Start Distributed Key Generation (DKG)" wide>
    <FG label="Threshold Scheme" required hint="T-of-N: T parties must collaborate to use the key">
      <Row2><FG label="Threshold (T)"><Inp placeholder="3" type="number"/></FG><FG label="Total Parties (N)"><Inp placeholder="5" type="number"/></FG></Row2>
    </FG>
    <FG label="Key Algorithm"><Sel><option>ECDSA-P256 (GG20 protocol)</option><option>ECDSA-P384 (GG20 protocol)</option><option>EdDSA-Ed25519 (FROST protocol)</option><option>Schnorr (FROST protocol)</option></Sel></FG>
    <FG label="Participants" hint="Select N users who will hold key shares">
      <Chk label="Admin A (alice@bank.com)" checked={true}/><Chk label="Admin B (bob@bank.com)" checked={true}/>
      <Chk label="HSM Partition (automated)" checked={true}/><Chk label="Escrow Agent (escrow@bank.com)" checked={false}/>
      <Chk label="DR Site (dr-admin@bank.com)" checked={false}/>
    </FG>
    <FG label="Ceremony Timeout"><Sel><option>30 minutes</option><option>1 hour</option><option>24 hours</option></Sel></FG>
    <FG label="Purpose"><Sel><option>Threshold signing (T-of-N sign)</option><option>Threshold decryption</option><option>Recovery key (backup)</option></Sel></FG>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Initiate DKG</Btn></div>
  </Modal>
</div>;};

