const Alerts=()=>{const [m,sM]=useState(null);return <div>
  <div style={{display:"flex",gap:12,marginBottom:14}}>
    <Stat l="Open" v="19" s="2 critical" c="red" i="🔴"/><Stat l="Today" v="13,213" s="97.2% auto-resolved" c="accent" i="🔔"/>
    <Stat l="Avg Response" v="4.2m" c="green" i="⏱"/><Stat l="Channels" v="5" s="Email, SIEM, PD, Slack, WH" c="blue" i="📡"/>
  </div>
  <Section title="Alert Rules" actions={<Btn small onClick={()=>sM("rule")}>+ Create Alert Rule</Btn>}>
    <div style={{fontSize:10,color:C.dim}}>Alert feed with severity badges...</div>
  </Section>
  <Modal open={m==="rule"} onClose={()=>sM(null)} title="Create Custom Alert Rule" wide>
    <FG label="Rule Name" required><Inp placeholder="bulk-decrypt-alert"/></FG>
    <FG label="Condition" required hint="Expression evaluated against every audit event">
      <Txt placeholder='event.action == "key.decrypt" AND event.details.batch_size > 1000' rows={2} mono/>
    </FG>
    <FG label="Severity"><Sel><option>CRITICAL</option><option>HIGH</option><option>MEDIUM</option><option>LOW</option></Sel></FG>
    <FG label="Alert Title Template"><Inp placeholder="Bulk decryption: {event.details.batch_size} items"/></FG>
    <FG label="Notification Channels"><Chk label="Email" checked={true}/><Chk label="SIEM" checked={true}/><Chk label="PagerDuty" checked={false}/><Chk label="Slack" checked={false}/><Chk label="Webhook" checked={false}/></FG>
    <div style={{display:"flex",justifyContent:"flex-end",gap:8,marginTop:12}}><Btn onClick={()=>sM(null)}>Cancel</Btn><Btn primary>Create Rule</Btn></div>
  </Modal>
</div>;};

