  "components": {
    "parameters": {
      "RequestIdHeader": {
        "name": "X-Request-ID",
        "in": "header",
        "required": false,
        "description": "Optional client correlation id. The service generates one when omitted.",
        "schema": {
          "type": "string"
        }
      },
      "TenantHeader": {
        "name": "X-Tenant-ID",
        "in": "header",
        "required": false,
        "description": "Alternative tenant scope header accepted by tenant-aware handlers.",
        "schema": {
          "type": "string",
          "example": "root"
        }
      },
      "TenantQuery": {
        "name": "tenant_id",
        "in": "query",
        "required": false,
        "description": "Tenant scope. Required for tenant-aware operations unless supplied in the request body or `X-Tenant-ID`.",
        "schema": {
          "type": "string",
          "example": "root"
        }
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "example": 20
        }
      },
      "IdPath": {
